 140  *===============================================================*
 141  *                     DECISION VARIABLES
 142  *===============================================================*
 143  Variables
 144      q(p,t) "Units produced"
 145      x(p,m,t) "Units shipped"
 146      y(c,s,p,t) "Components purchased"
 147      I(p,t) "Inventory"
 148      B(m,t) "Unmet demand"
 149      z      "Total cost";
 150   
 151  Positive Variables q, x, y, I, B;
 152   
 153  Equations
 154      DemandSatisfaction(m,t)   "Demand constraints"
 155      InitialBacklog(m)         "Initial backlog"
 156      ClearBacklog(m)           "clear backlogs"
 157      InventoryBalance1(p)      "Opening inventory"
 158      InventoryBalance(p,t)     "Inventory flow"
 159      PlantCap(p,t)             "Production capacity"
 160      SupplierAvail(c,s,p,t)    "Supplier limits"
 161      ComponentRequirement(c,p,t) "BOM requirements"
 162      Sustainability            "Emission cap"
 163      Objective                 "Total cost minimization";
 164   
 165   
 166  Objective..
 167      z =e= SUM(t,
 168              SUM(p,       Cprod(p)      * q(p,t))
 169            + SUM((p,m),   Cship(p,m)    * x(p,m,t))
 170            + SUM((p,c,s), Ccomp(c,s,p)  * y(c,s,p,t))
 171            + SUM(p,       h(p)          * I(p,t))
 172            + SUM(m,       pen(m)        * B(m,t))
 173            + SUM((p,m),   tau_fg(p)      * MakeCost(p) * x(p,m,t))
 174            + SUM((c,s,p), tau_comp(c,s,p) * Ccomp(c,s,p) * y(c,s,p,t))
 175            )
 176            + CO * ( SUM((p,m,t), Eship(p,m)*x(p,m,t))
 177                   + SUM((p,t),   Eprod(p)   *q(p,t))
 178                  );
 179  * Rolling Backlog Demand Constraint
 180  DemandSatisfaction(m,t)..
 181      SUM(p, x(p,m,t)) + B(m,t) =e= D(m,t) + (B(m,t-1)$(ord(t)>1));
 182   
 183  InitialBacklog(m)..
 184      B(m,'1') =e= 0;
 185   
 186  ClearBacklog(m)..
 187      B(m,'12') =e= 0;
 188   
 189  InventoryBalance1(p)..
 190      I(p,'1') =e= q(p,'1') - SUM(m, x(p,m,'1'));
 191   
 192  InventoryBalance(p,t)$(ord(t) > 1)..
 193      I(p,t) =e= I(p,t-1) + q(p,t) - SUM(m, x(p,m,t));
 194   
 195  PlantCap(p,t).. q(p,t) =l= Cap(p);
 196   
 197  ComponentRequirement(c,p,t)..
 198      SUM(s, y(c,s,p,t)) =e= a(c) * q(p,t);
 199   
 200  SupplierAvail(c,s,p,t)..
 201      y(c,s,p,t) =l= Supply(c,s,p,t);
 202   
 203  Sustainability..
 204      SUM((p,m,t), Eship(p,m) * x(p,m,t))
 205    + SUM((p,t),   Eprod(p)   * q(p,t))
 206    =l= Emax;
 207   
 208  Model Project /all/;
 209  Solve Project using lp minimizing z;
 210   
 211  Display z.l, q.l, x.l, I.l, B.l, y.l;
